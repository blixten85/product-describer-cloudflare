{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "product-describer-processor",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  // Krävs av @sentry/cloudflare (AsyncLocalStorage-API).
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "product_describer",
      "database_id": "f1301925-95c3-47c7-b513-a25d4cfaf881"
    }
  ],
  "r2_buckets": [
    {
      "binding": "UPLOADS",
      "bucket_name": "product-describer-uploads"
    }
  ],
  "queues": {
    "consumers": [
      {
        "queue": "product-describer-jobs",
        "max_batch_size": 10,
        "max_retries": 10,
        "max_concurrency": 4
      }
    ],
    "producers": [
      {
        "queue": "product-describer-jobs",
        "binding": "JOB_QUEUE"
      }
    ]
  }
}
