{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "schedule:weekly",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separateMajorReleases",
    ":prConcurrentLimit10",
    ":rebaseStalePrs"
  ],
  "timezone": "Europe/Stockholm",
  "labels": [
    "dependencies",
    "renovate"
  ],
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "after 3am and before 3:30am on saturday"
    ]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security"
    ]
  },
  "packageRules": [
    {
      "description": "Group all patch/minor updates into one PR per run (reduces CodeRabbit review-count load under the shared 5/hour quota); auto-merge the bundle on green CI + review",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "non-major dependencies",
      "automerge": true
    },
    {
      "matchDepTypes": [
        "devDependencies"
      ],
      "groupName": "dev-dependencies",
      "automerge": true
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions"
    },
    {
      "description": "wrangler (senaste 4.107.0 inkluderat) kräver @cloudflare/workers-types ^4.x som peer dependency — håll tillbaka major-uppdateringar tills wrangler själv stöder v5 (se stängd PR #77)",
      "matchPackageNames": ["@cloudflare/workers-types"],
      "allowedVersions": "<5.0.0"
    }
  ],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 10,
  "schedule": [
    "after 3am and before 3:30am on saturday"
  ]
}